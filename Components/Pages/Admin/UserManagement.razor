    private async Task DeleteLocationAsync(SavedLocationDto loc)
    {
        deletingLocationId = loc.Id;
        try
        {
            var result = await ProfileService.DeleteLocationAsync(loc.Id, profileUser?.Id);
            if (result.Success) { savedLocations.Remove(loc); toast?.ShowSuccess($"Location '{loc.Label}' deleted."); }
            else toast?.ShowError(result.Message ?? "Failed to delete location.");
