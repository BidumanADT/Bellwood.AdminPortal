@page "/admin/users"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin")]
@using Microsoft.AspNetCore.Components.Authorization
@using Bellwood.AdminPortal.Models
@using Bellwood.AdminPortal.Services
@using Bellwood.AdminPortal.Components.Shared
@inject IUserManagementService UserService
@inject IProfileApiService ProfileService
@inject NavigationManager Navigation

<PageTitle>User Management - Bellwood Elite</PageTitle>

<ToastNotification @ref="toast" />

<AuthorizeView Roles="admin">
    <Authorized>
        <div class="container-fluid py-4">
            <div class="row mb-4">
                <div class="col-md-8">
                    <h2 class="text-bellwood-gold">👥 User Management</h2>
                    <p class="text-muted">Create users and manage role assignments</p>
                </div>
                <div class="col-md-4 d-flex justify-content-md-end align-items-start">
                    <button class="btn btn-primary" @onclick="ShowCreateModal">
                        ➕ Create User
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show">
                    ✅ @successMessage
                    <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    ⚠️ @errorMessage
                    <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                </div>
            }

            <!-- Users Table -->
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-bellwood-gold" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3 text-muted">Loading users...</p>
                </div>
            }
            else if (!users.Any())
            {
                <div class="alert alert-info">
                    No users found with the selected filters.
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">
                            Users (@users.Count)
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-white">Username</th>
                                        <th class="text-white">Email</th>
                                        <th class="text-white">Roles</th>
                                        <th class="text-white">Created At</th>
                                        <th class="text-white">Modified At</th>
                                        <th class="text-white">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in users)
                                    {
                                        <tr>
                                            <td>
                                                <strong class="text-white">
                                                    @if (!string.IsNullOrEmpty(user.Username))
                                                    {
                                                        @user.Username
                                                    }
                                                    else if (!string.IsNullOrEmpty(user.Email))
                                                    {
                                                        @user.Email
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted fst-italic">User @user.Id.Substring(0, 8)</span>
                                                    }
                                                </strong>
                                            </td>
                                            <td class="text-light">
                                                @if (!string.IsNullOrEmpty(user.Email))
                                                {
                                                    @user.Email
                                                }
                                                else
                                                {
                                                    <span class="text-muted fst-italic">No email</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="text-white">@FormatRole(user)</span>
                                            </td>
                                            <td>
                                                <small class="text-light">@FormatDateTime(user.CreatedAtUtc)</small>
                                            </td>
                                            <td>
                                                <small class="text-light">@FormatDateTime(user.ModifiedAtUtc)</small>
                                            </td>
                                            <td class="d-flex flex-wrap gap-2">
                                                <button class="btn btn-sm btn-outline-primary"
                                                        @onclick="() => ShowRoleChangeModal(user)">
                                                    Edit Roles
                                                </button>
                                                @if (IsBookerUser(user))
                                                {
                                                    <button class="btn btn-sm btn-outline-info"
                                                            @onclick="() => ShowProfileModal(user)">
                                                        👤 Profile
                                                    </button>
                                                }
                                                @if (disableEndpointAvailable)
                                                {
                                                    <button class="btn btn-sm @(user.IsDisabled ? "btn-outline-success" : "btn-outline-danger")"
                                                            @onclick="() => ToggleUserDisabled(user)"
                                                            disabled="@(statusUpdatingUserId == user.Id)">
                                                        @if (statusUpdatingUserId == user.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm"></span>
                                                        }
                                                        else
                                                        {
                                                            <span>@(user.IsDisabled ? "Enable" : "Disable")</span>
                                                        }
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary" 
                                                          title="User disable feature coming in next release"
                                                          style="cursor: help; padding: 0.375rem 0.75rem;">
                                                        🚧 Disable: Not Yet Available
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- ── Create User Modal ────────────────────────────────────────── -->
            @if (showCreateModal)
            {
                <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content" style="background: var(--bellwood-charcoal); border: 1px solid var(--bellwood-gold);">
                            <div class="modal-header">
                                <h5 class="modal-title text-white">Create User</h5>
                                <button type="button" class="btn-close btn-close-white" @onclick="CloseCreateModal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label text-white">Email</label>
                                    <input type="email" class="form-control" @bind="newUserEmail" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-white">
                                        First Name
                                        @if (selectedCreateRoles.Contains("booker"))
                                        {
                                            <span class="text-danger ms-1">*</span>
                                        }
                                    </label>
                                    <input type="text" class="form-control" @bind="newUserFirstName" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-white">
                                        Last Name
                                        @if (selectedCreateRoles.Contains("booker"))
                                        {
                                            <span class="text-danger ms-1">*</span>
                                        }
                                    </label>
                                    <input type="text" class="form-control" @bind="newUserLastName" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-white">Roles</label>
                                    <div class="d-flex flex-wrap gap-3">
                                        @foreach (var role in availableRoles)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       checked="@selectedCreateRoles.Contains(role)"
                                                       @onchange="(args) => ToggleCreateRole(role, args.Value)" />
                                                <label class="form-check-label text-light">@GetRoleLabel(role)</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                                @if (selectedCreateRoles.Contains("booker"))
                                {
                                    <div class="mb-3">
                                        <label class="form-label text-white">
                                            Phone <span class="text-danger ms-1">*</span>
                                        </label>
                                        <input type="tel" class="form-control" @bind="newUserPhone"
                                               placeholder="(555) 000-0000" />
                                        <small class="text-muted">Required so the booker can be contacted at ride time.</small>
                                    </div>
                                }
                                <div class="mb-3">
                                    <label class="form-label text-white">Temporary Password</label>
                                    <input type="password" class="form-control" @bind="temporaryPassword" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-white">Confirm Password</label>
                                    <input type="password" class="form-control" @bind="confirmPassword" />
                                    <small class="text-muted">Minimum 10 characters.</small>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                                <button type="button" class="btn btn-primary" @onclick="CreateUserAsync" disabled="@isCreating">
                                    @if (isCreating)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Create User
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- ── Role Change Modal ────────────────────────────────────────── -->
            @if (showRolesModal && selectedUser != null)
            {
                <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content" style="background: var(--bellwood-charcoal); border: 1px solid var(--bellwood-gold);">
                            <div class="modal-header">
                                <h5 class="modal-title text-white">Edit User Roles</h5>
                                <button type="button" class="btn-close btn-close-white" @onclick="CancelRoleChange"></button>
                            </div>
                            <div class="modal-body">
                                <p class="text-light">
                                    <strong class="text-white">User:</strong>
                                    <span class="text-bellwood-gold">
                                        @if (!string.IsNullOrEmpty(selectedUser.Username))
                                        {
                                            @selectedUser.Username
                                        }
                                        else
                                        {
                                            @selectedUser.Email
                                        }
                                    </span>
                                    @if (!string.IsNullOrEmpty(selectedUser.Email) && !string.IsNullOrEmpty(selectedUser.Username))
                                    {
                                        <br />
                                        <strong class="text-white">Email:</strong> <span class="text-light">@selectedUser.Email</span>
                                    }
                                    <br />
                                    <strong class="text-white">Current Roles:</strong> <span class="text-light">@FormatRoles(selectedUser)</span>
                                </p>
                                <div class="mb-3">
                                    <label class="form-label text-white">Role</label>
                                    <div class="d-flex flex-wrap gap-3">
                                        @foreach (var role in availableRoles)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="radio"
                                                       name="userRole"
                                                       id="role-@role"
                                                       checked="@selectedRoles.Contains(role)"
                                                       @onchange="() => SelectSingleRole(role)" />
                                                <label class="form-check-label text-light" for="role-@role">@GetRoleLabel(role)</label>
                                            </div>
                                        }
                                    </div>
                                    <small class="text-muted">Users can only have one role.</small>
                                </div>
                                <div class="alert alert-warning">
                                    <strong>ℹ️ Note:</strong>
                                    <ul class="mb-0">
                                        <li>Role changes take effect on the user's next login.</li>
                                        <li>At least one role must remain assigned.</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelRoleChange">
                                    Cancel
                                </button>
                                <button type="button" class="btn btn-primary"
                                        @onclick="ConfirmRoleChange"
                                        disabled="@isUpdatingRoles">
                                    @if (isUpdatingRoles)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Save Roles
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- ── Booker Profile Modal (Saved Passengers + Saved Locations) ── -->
            @if (showProfileModal && profileUser != null)
            {
                <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.6);">
                    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
                        <div class="modal-content" style="background: var(--bellwood-charcoal); border: 1px solid var(--bellwood-gold);">
                            <div class="modal-header">
                                <h5 class="modal-title text-white">
                                    👤 Booker Profile —
                                    <span class="text-bellwood-gold">
                                        @(!string.IsNullOrEmpty(profileUser.Username) ? profileUser.Username : profileUser.Email)
                                    </span>
                                </h5>
                                <button type="button" class="btn-close btn-close-white" @onclick="CloseProfileModal"></button>
                            </div>

                            <!-- Tab bar -->
                            <div class="px-3 pt-2">
                                <ul class="nav nav-tabs">
                                    <li class="nav-item">
                                        <button class="nav-link @(profileTab == "passengers" ? "active" : "text-light")"
                                                @onclick='() => profileTab = "passengers"'>
                                            🧑 Saved Passengers
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link @(profileTab == "locations" ? "active" : "text-light")"
                                                @onclick='() => profileTab = "locations"'>
                                            📍 Saved Locations
                                        </button>
                                    </li>
                                </ul>
                            </div>

                            <div class="modal-body">
                                @if (isProfileLoading)
                                {
                                    <div class="text-center py-4">
                                        <div class="spinner-border text-bellwood-gold" role="status"></div>
                                        <p class="mt-2 text-muted">Loading…</p>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(profileError))
                                {
                                    <div class="alert alert-danger">⚠️ @profileError</div>
                                }
                                else if (profileTab == "passengers")
                                {
                                    <!-- Saved Passengers tab -->
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="text-white mb-0">Saved Passengers (@savedPassengers.Count)</h6>
                                        <button class="btn btn-sm btn-primary" @onclick="ShowAddPassengerForm">
                                            ➕ Add Passenger
                                        </button>
                                    </div>

                                    @if (showPassengerForm)
                                    {
                                        <div class="card mb-3" style="border: 1px solid var(--bellwood-gold);">
                                            <div class="card-body">
                                                <h6 class="text-white">@(editingPassengerId == null ? "New Passenger" : "Edit Passenger")</h6>
                                                <div class="row g-2">
                                                    <div class="col-md-6">
                                                        <label class="form-label text-white">First Name <span class="text-danger">*</span></label>
                                                        <input type="text" class="form-control" @bind="paxFirstName" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label text-white">Last Name <span class="text-danger">*</span></label>
                                                        <input type="text" class="form-control" @bind="paxLastName" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label text-white">Phone</label>
                                                        <input type="tel" class="form-control" @bind="paxPhone" placeholder="(555) 000-0000" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label text-white">Email</label>
                                                        <input type="email" class="form-control" @bind="paxEmail" />
                                                    </div>
                                                </div>
                                                @if (!string.IsNullOrEmpty(paxFormError))
                                                {
                                                    <div class="alert alert-danger mt-2 py-1">@paxFormError</div>
                                                }
                                                <div class="mt-3 d-flex gap-2">
                                                    <button class="btn btn-primary btn-sm" @onclick="SavePassengerAsync" disabled="@isSavingPassenger">
                                                        @if (isSavingPassenger) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                        Save
                                                    </button>
                                                    <button class="btn btn-secondary btn-sm" @onclick="CancelPassengerForm">Cancel</button>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @if (!savedPassengers.Any())
                                    {
                                        <div class="alert alert-info">No saved passengers yet.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover table-sm">
                                                <thead>
                                                    <tr>
                                                        <th class="text-white">Name</th>
                                                        <th class="text-white">Phone</th>
                                                        <th class="text-white">Email</th>
                                                        <th class="text-white">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var p in savedPassengers)
                                                    {
                                                        <tr>
                                                            <td class="text-light">@p.DisplayName</td>
                                                            <td class="text-light">@(p.PhoneNumber ?? "—")</td>
                                                            <td class="text-light">@(p.EmailAddress ?? "—")</td>
                                                            <td>
                                                                <button class="btn btn-sm btn-outline-secondary me-1"
                                                                        @onclick="() => EditPassenger(p)">Edit</button>
                                                                <button class="btn btn-sm btn-outline-danger"
                                                                        @onclick="() => DeletePassengerAsync(p)"
                                                                        disabled="@(deletingPassengerId == p.Id)">
                                                                    @if (deletingPassengerId == p.Id) { <span class="spinner-border spinner-border-sm"></span> }
                                                                    else { <span>Delete</span> }
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                }
                                else if (profileTab == "locations")
                                {
                                    <!-- Saved Locations tab -->
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="text-white mb-0">Saved Locations (@savedLocations.Count)</h6>
                                        <button class="btn btn-sm btn-primary" @onclick="ShowAddLocationForm">
                                            ➕ Add Location
                                        </button>
                                    </div>

                                    @if (showLocationForm)
                                    {
                                        <div class="card mb-3" style="border: 1px solid var(--bellwood-gold);">
                                            <div class="card-body">
                                                <h6 class="text-white">@(editingLocationId == null ? "New Location" : "Edit Location")</h6>
                                                <div class="row g-2">
                                                    <div class="col-md-6">
                                                        <label class="form-label text-white">Label <span class="text-danger">*</span></label>
                                                        <input class="form-control" @bind="locLabel" placeholder="Home, Office…" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label text-white">Address <span class="text-danger">*</span></label>
                                                        <input class="form-control" @bind="locAddress" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label text-white">Latitude <span class="text-danger">*</span></label>
                                                        <input class="form-control" type="number" step="any" @bind="locLat" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label text-white">Longitude <span class="text-danger">*</span></label>
                                                        <input class="form-control" type="number" step="any" @bind="locLng" />
                                                    </div>
                                                    <div class="col-md-6 d-flex align-items-end">
                                                        <div class="form-check ms-1">
                                                            <input class="form-check-input" type="checkbox" @bind="locIsFavorite" id="locFav" />
                                                            <label class="form-check-label text-light" for="locFav">⭐ Favorite</label>
                                                        </div>
                                                    </div>
                                                </div>
                                                @if (!string.IsNullOrEmpty(locFormError))
                                                {
                                                    <div class="alert alert-danger mt-2 py-1">@locFormError</div>
                                                }
                                                <div class="mt-3 d-flex gap-2">
                                                    <button class="btn btn-primary btn-sm" @onclick="SaveLocationAsync" disabled="@isSavingLocation">
                                                        @if (isSavingLocation) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                        Save
                                                    </button>
                                                    <button class="btn btn-secondary btn-sm" @onclick="CancelLocationForm">Cancel</button>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @if (!savedLocations.Any())
                                    {
                                        <div class="alert alert-info">No saved locations yet.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover table-sm">
                                                <thead>
                                                    <tr>
                                                        <th class="text-white">Label</th>
                                                        <th class="text-white">Address</th>
                                                        <th class="text-white">Fav</th>
                                                        <th class="text-white">Uses</th>
                                                        <th class="text-white">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var loc in savedLocations)
                                                    {
                                                        <tr>
                                                            <td class="text-light">@loc.Label</td>
                                                            <td class="text-light"><small>@loc.Address</small></td>
                                                            <td class="text-center">@(loc.IsFavorite ? "⭐" : "")</td>
                                                            <td class="text-light text-center">@loc.UseCount</td>
                                                            <td>
                                                                <button class="btn btn-sm btn-outline-secondary me-1"
                                                                        @onclick="() => EditLocation(loc)">Edit</button>
                                                                <button class="btn btn-sm btn-outline-danger"
                                                                        @onclick="() => DeleteLocationAsync(loc)"
                                                                        disabled="@(deletingLocationId == loc.Id)">
                                                                    @if (deletingLocationId == loc.Id) { <span class="spinner-border spinner-border-sm"></span> }
                                                                    else { <span>Delete</span> }
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                }
                            </div>

                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CloseProfileModal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        @{
            Navigation.NavigateTo("/login");
        }
    </NotAuthorized>
</AuthorizeView>

@code {
    // ── Users list ────────────────────────────────────────────────────────────

    private List<UserDto> users = new();
    private UserDto? selectedUser;

    private bool isLoading = false;
    private bool isUpdatingRoles = false;
    private bool isCreating = false;
    private string? statusUpdatingUserId;
    private string? successMessage;
    private string? errorMessage;
    private bool showCreateModal = false;
    private bool showRolesModal = false;
    private bool disableEndpointAvailable = false;

    private readonly List<string> availableRoles = new() { "booker", "driver", "dispatcher", "admin" };
    private bool IsAdmin => selectedRoles.Contains("admin");
    private static bool IsBookerUser(UserDto user) =>
        user.Roles.Any(r => r.Equals("booker", StringComparison.OrdinalIgnoreCase));

    private HashSet<string> selectedRoles = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> selectedCreateRoles = new(StringComparer.OrdinalIgnoreCase);

    // Create-user form fields
    private string newUserEmail = string.Empty;
    private string newUserFirstName = string.Empty;
    private string newUserLastName = string.Empty;
    private string newUserPhone = string.Empty;
    private string temporaryPassword = string.Empty;
    private string confirmPassword = string.Empty;

    private ToastNotification? toast;

    // ── Profile modal state ───────────────────────────────────────────────────

    private UserDto? profileUser;
    private bool showProfileModal = false;
    private string profileTab = "passengers";
    private bool isProfileLoading = false;
    private string? profileError;

    // Saved passengers
    private List<SavedPassengerDto> savedPassengers = new();
    private bool showPassengerForm = false;
    private string? editingPassengerId;
    private string paxFirstName = string.Empty;
    private string paxLastName = string.Empty;
    private string paxPhone = string.Empty;
    private string paxEmail = string.Empty;
    private string? paxFormError;
    private bool isSavingPassenger = false;
    private string? deletingPassengerId;

    // Saved locations
    private List<SavedLocationDto> savedLocations = new();
    private bool showLocationForm = false;
    private string? editingLocationId;
    private string locLabel = string.Empty;
    private string locAddress = string.Empty;
    private double locLat;
    private double locLng;
    private bool locIsFavorite;
    private string? locFormError;
    private bool isSavingLocation = false;
    private string? deletingLocationId;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            users = await UserService.GetUsersAsync();
        }
        catch (UnauthorizedAccessException ex)
        {
            errorMessage = ex.Message;
            toast?.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load users: {ex.Message}";
            toast?.ShowError(errorMessage);
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Role change modal ─────────────────────────────────────────────────────

    private void ShowRoleChangeModal(UserDto user)
    {
        selectedUser = user;
        selectedRoles = new HashSet<string>(
            (user.Roles ?? new List<string>()).Select(NormalizeRoleSelection),
            StringComparer.OrdinalIgnoreCase);
        successMessage = null;
        errorMessage = null;
        showRolesModal = true;
    }

    private void CancelRoleChange()
    {
        selectedUser = null;
        selectedRoles.Clear();
        showRolesModal = false;
    }

    private async Task ConfirmRoleChange()
    {
        if (selectedUser == null) return;

        if (!selectedRoles.Any())
        {
            errorMessage = "Select at least one role before saving.";
            toast?.ShowError(errorMessage);
            return;
        }

        if (selectedRoles.Count > 1)
        {
            errorMessage = "Users can only have one role. Please select only one.";
            toast?.ShowError(errorMessage);
            return;
        }

        isUpdatingRoles = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var newRole = selectedRoles.First();
            var result = await UserService.UpdateUserRoleAsync(selectedUser.Id, newRole);

            if (result.Success)
            {
                var id = !string.IsNullOrEmpty(selectedUser.Username) ? selectedUser.Username : selectedUser.Email;
                successMessage = $"Role updated for {id} to {GetRoleLabel(newRole)}.";
                toast?.ShowSuccess(successMessage);
                await LoadUsersAsync();
                CancelRoleChange();
            }
            else
            {
                errorMessage = result.Message ?? "Failed to update role";
                toast?.ShowError(errorMessage);
            }
        }
        catch (UnauthorizedAccessException ex)
        {
            errorMessage = ex.Message;
            toast?.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update role: {ex.Message}";
            toast?.ShowError(errorMessage);
        }
        finally
        {
            isUpdatingRoles = false;
        }
    }

    // ── Create user modal ─────────────────────────────────────────────────────

    private void ShowCreateModal()
    {
        showCreateModal = true;
        successMessage = null;
        errorMessage = null;
    }

    private void CloseCreateModal()
    {
        showCreateModal = false;
        ClearCreateForm();
    }

    private async Task CreateUserAsync()
    {
        var validationError = ValidateCreateForm();
        if (!string.IsNullOrEmpty(validationError))
        {
            errorMessage = validationError;
            toast?.ShowError(validationError);
            return;
        }

        isCreating = true;
        errorMessage = null;
        successMessage = null;

        var isBooker = selectedCreateRoles.Contains("booker");
        var email = newUserEmail.Trim();
        var firstName = newUserFirstName.Trim();
        var lastName = newUserLastName.Trim();
        var phone = newUserPhone.Trim();

        try
        {
            var request = new CreateUserRequest
            {
                Email = email,
                FirstName = string.IsNullOrEmpty(firstName) ? null : firstName,
                LastName = string.IsNullOrEmpty(lastName) ? null : lastName,
                Roles = selectedCreateRoles.ToList(),
                TemporaryPassword = temporaryPassword
            };

            var result = await UserService.CreateUserAsync(request);

            if (!result.Success)
            {
                errorMessage = result.Message ?? "Failed to create user.";
                toast?.ShowError(errorMessage);
                return;
            }

            if (isBooker && !string.IsNullOrEmpty(result.UserId))
            {
                var profileResult = await UserService.UpdateBookerProfileAsync(
                    result.UserId,
                    new UpdateBookerProfileRequest
                    {
                        FirstName    = firstName,
                        LastName     = lastName,
                        EmailAddress = email,
                        PhoneNumber  = phone
                    });

                if (!profileResult.Success)
                {
                    successMessage = $"Booker {email} created. Warning: phone could not be saved — {profileResult.Message}";
                    toast?.ShowSuccess(successMessage);
                }
                else
                {
                    successMessage = $"Booker {email} created successfully.";
                    toast?.ShowSuccess(successMessage);
                }
            }
            else
            {
                successMessage = $"User {email} created successfully.";
                toast?.ShowSuccess(successMessage);
            }

            CloseCreateModal();
            await LoadUsersAsync();
        }
        catch (UnauthorizedAccessException ex)
        {
            errorMessage = ex.Message;
            toast?.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create user: {ex.Message}";
            toast?.ShowError(errorMessage);
        }
        finally
        {
            temporaryPassword = string.Empty;
            confirmPassword = string.Empty;
            isCreating = false;
        }
    }

    // ── Disable / enable ──────────────────────────────────────────────────────

    private async Task ToggleUserDisabled(UserDto user)
    {
        if (statusUpdatingUserId != null) return;

        statusUpdatingUserId = user.Id;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await UserService.SetUserDisabledAsync(user.Id, !user.IsDisabled);
            if (result.EndpointNotFound)
            {
                disableEndpointAvailable = false;
                errorMessage = result.Message ?? "Disable endpoint not available.";
                toast?.ShowError(errorMessage);
                return;
            }

            if (result.Success)
            {
                user.IsDisabled = !user.IsDisabled;
                var id = !string.IsNullOrEmpty(user.Username) ? user.Username : user.Email;
                successMessage = $"{id} {(user.IsDisabled ? "disabled" : "enabled")}.";
                toast?.ShowSuccess(successMessage);
            }
            else
            {
                errorMessage = result.Message ?? "Failed to update user status.";
                toast?.ShowError(errorMessage);
            }
        }
        catch (UnauthorizedAccessException ex) { errorMessage = ex.Message; toast?.ShowError(ex.Message); }
        catch (Exception ex) { errorMessage = $"Failed to update user status: {ex.Message}"; toast?.ShowError(errorMessage); }
        finally { statusUpdatingUserId = null; }
    }

    // ── Profile modal ─────────────────────────────────────────────────────────

    private async Task ShowProfileModal(UserDto user)
    {
        profileUser = user;
        profileTab = "passengers";
        profileError = null;
        showProfileModal = true;
        ResetPassengerForm();
        ResetLocationForm();
        await LoadProfileDataAsync();
    }

    private void CloseProfileModal()
    {
        showProfileModal = false;
        profileUser = null;
        savedPassengers.Clear();
        savedLocations.Clear();
        ResetPassengerForm();
        ResetLocationForm();
    }

    private async Task LoadProfileDataAsync()
    {
        if (profileUser == null) return;

        isProfileLoading = true;
        profileError = null;

        try
        {
            var userId = string.IsNullOrEmpty(profileUser.Id) ? null : profileUser.Id;

            // Sequential calls — ValueTask tuple-await is not available without extra packages
            savedPassengers = await ProfileService.GetSavedPassengersAsync(userId);
            savedLocations  = await ProfileService.GetSavedLocationsAsync(userId);
        }
        catch (UnauthorizedAccessException ex)
        {
            profileError = ex.Message;
            toast?.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            profileError = $"Failed to load profile data: {ex.Message}";
            toast?.ShowError(profileError);
        }
        finally
        {
            isProfileLoading = false;
        }
    }

    // ── Passenger form ────────────────────────────────────────────────────────

    private void ShowAddPassengerForm() { ResetPassengerForm(); showPassengerForm = true; }

    private void EditPassenger(SavedPassengerDto p)
    {
        editingPassengerId = p.Id;
        paxFirstName = p.FirstName;
        paxLastName  = p.LastName;
        paxPhone     = p.PhoneNumber ?? string.Empty;
        paxEmail     = p.EmailAddress ?? string.Empty;
        paxFormError = null;
        showPassengerForm = true;
    }

    private void CancelPassengerForm() => ResetPassengerForm();

    private void ResetPassengerForm()
    {
        showPassengerForm  = false;
        editingPassengerId = null;
        paxFirstName = paxLastName = paxPhone = paxEmail = string.Empty;
        paxFormError = null;
    }

    private async Task SavePassengerAsync()
    {
        if (string.IsNullOrWhiteSpace(paxFirstName) || string.IsNullOrWhiteSpace(paxLastName))
        {
            paxFormError = "First name and last name are required.";
            return;
        }

        isSavingPassenger = true;
        paxFormError = null;
        var userId = profileUser?.Id;

        try
        {
            var req = new SavedPassengerRequest
            {
                FirstName    = paxFirstName.Trim(),
                LastName     = paxLastName.Trim(),
                PhoneNumber  = string.IsNullOrWhiteSpace(paxPhone) ? null : paxPhone.Trim(),
                EmailAddress = string.IsNullOrWhiteSpace(paxEmail) ? null : paxEmail.Trim()
            };

            var result = editingPassengerId == null
                ? await ProfileService.AddPassengerAsync(req, userId)
                : await ProfileService.UpdatePassengerAsync(editingPassengerId, req, userId);

            if (result.Success)
            {
                toast?.ShowSuccess(editingPassengerId == null ? "Passenger added." : "Passenger updated.");
                ResetPassengerForm();
                await LoadProfileDataAsync();
            }
            else
            {
                paxFormError = result.Message ?? "Failed to save passenger.";
            }
        }
        catch (UnauthorizedAccessException ex) { paxFormError = ex.Message; }
        catch (Exception ex) { paxFormError = $"Error: {ex.Message}"; }
        finally { isSavingPassenger = false; }
    }

    private async Task DeletePassengerAsync(SavedPassengerDto p)
    {
        deletingPassengerId = p.Id;
        try
        {
            var result = await ProfileService.DeletePassengerAsync(p.Id, profileUser?.Id);
            if (result.Success) { savedPassengers.Remove(p); toast?.ShowSuccess($"Passenger '{p.DisplayName}' deleted."); }
            else toast?.ShowError(result.Message ?? "Failed to delete passenger.");
        }
        catch (UnauthorizedAccessException ex) { toast?.ShowError(ex.Message); }
        catch (Exception ex) { toast?.ShowError($"Error: {ex.Message}"); }
        finally { deletingPassengerId = null; }
    }

