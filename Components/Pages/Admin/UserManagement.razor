    // ── Shared helpers ────────────────────────────────────────────────────────

    private void ToggleCreateRole(string role, object? value) => ToggleRoleSelection(selectedCreateRoles, role, value);
    private void ToggleEditRole(string role, object? value)   => ToggleRoleSelection(selectedRoles, role, value);

    private void SelectSingleRole(string role) { selectedRoles.Clear(); selectedRoles.Add(role); }

    private static void ToggleRoleSelection(HashSet<string> selection, string role, object? value)
    {
        if (value is bool isChecked)
        {
            if (isChecked) selection.Add(role);
            else           selection.Remove(role);
        }
    }

    private string? ValidateCreateForm()
    {
        if (string.IsNullOrWhiteSpace(newUserEmail))
            return "Email is required.";
        if (!selectedCreateRoles.Any())
            return "Select at least one role.";
        if (selectedCreateRoles.Contains("booker"))
        {
            if (string.IsNullOrWhiteSpace(newUserFirstName)) return "First name is required for booker accounts.";
            if (string.IsNullOrWhiteSpace(newUserLastName))  return "Last name is required for booker accounts.";
            if (string.IsNullOrWhiteSpace(newUserPhone))     return "Phone number is required for booker accounts.";
        }
        if (string.IsNullOrWhiteSpace(temporaryPassword) || temporaryPassword.Length < 10)
            return "Temporary password must be at least 10 characters.";
        if (!string.Equals(temporaryPassword, confirmPassword, StringComparison.Ordinal))
            return "Temporary password and confirmation do not match.";
        return null;
    }

    private void ClearCreateForm()
    {
        newUserEmail = newUserFirstName = newUserLastName = newUserPhone =
            temporaryPassword = confirmPassword = string.Empty;
        selectedCreateRoles.Clear();
    }

    private string NormalizeRoleSelection(string role) =>
        availableRoles.FirstOrDefault(r => r.Equals(role, StringComparison.OrdinalIgnoreCase)) ?? role;

    private static string GetRoleLabel(string role) => role.ToLowerInvariant() switch
    {
        "admin"      => "Admin",
        "dispatcher" => "Dispatcher",
        "driver"     => "Driver",
        "booker"     => "Booker",
        _            => role
    };

    private static string FormatDateTime(DateTime? dt)
    {
        if (!dt.HasValue || dt.Value == DateTime.MinValue || dt.Value.Year == 1) return "—";
        return dt.Value.ToLocalTime().ToString("g");
    }

    private static string FormatRole(UserDto user) =>
        string.IsNullOrEmpty(user.Role) ? "None" : GetRoleLabel(user.Role);

    private static string FormatRoles(UserDto user)
    {
        if (!string.IsNullOrEmpty(user.Role)) return GetRoleLabel(user.Role);
        if (user.Roles == null || user.Roles.Count == 0) return "None";
        return string.Join(", ", user.Roles.Select(GetRoleLabel));
    }
}
