@page "/login"
@* No @rendermode — this page must be SSR so HttpContext is available for SignInAsync. *@
@layout Layout.EmptyLayout
@using System.Net.Http.Json
@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Components
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Bellwood Elite - Staff Login</PageTitle>

<div class="container">
    <div class="row justify-content-center" style="margin-top: 100px;">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-center mb-4">
                        <img src="/images/bellwood_elite_icon.png"
                             alt="Bellwood Elite"
                             style="width: 80px; height: 80px; object-fit: contain;"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                        <span class="display-4" style="display: none;"></span>
                    </div>
                    <h3 class="text-center mb-2" style="color: var(--bellwood-gold);">
                        Bellwood Elite
                    </h3>
                    <h5 class="text-center mb-4">Staff Portal Login</h5>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="login" data-enhance="false">
                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <InputText @bind-Value="loginModel!.Username"
                                       class="form-control"
                                       placeholder="Username" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <InputText @bind-Value="loginModel!.Password"
                                       type="password"
                                       class="form-control"
                                       placeholder="Password" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            Login
                        </button>
                    </EditForm>

                    <div class="text-center mt-3">
                        <small class="text-muted">
                            Dev: alice/password (admin), diana/password (dispatcher)
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private LoginModel? loginModel { get; set; }

    private string? errorMessage;

    protected override void OnInitialized()
    {
        loginModel ??= new();

        // If the user is already authenticated (has a valid cookie),
        // redirect straight to /main instead of showing the login form.
        if (HttpContext.User?.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/main", forceLoad: true);
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null;

        try
        {
            Logger.LogInformation("[Login] Starting login for user: {Username}", loginModel!.Username);

            var client = HttpFactory.CreateClient("AuthServer");
            var response = await client.PostAsJsonAsync("/api/auth/login", new
            {
                username = loginModel.Username,
                password = loginModel.Password
            });

            Logger.LogInformation("[Login] Auth server response: {StatusCode}", response.StatusCode);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Invalid username or password.";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
            if (result?.AccessToken == null)
            {
                errorMessage = "Invalid response from auth server.";
                return;
            }

            Logger.LogInformation("[Login] Token received, length: {Length}", result.AccessToken.Length);

            // Decode JWT to extract claims for the auth cookie
            var handler = new JwtSecurityTokenHandler();
            if (!handler.CanReadToken(result.AccessToken))
            {
                errorMessage = "Invalid token format from auth server.";
                return;
            }

            var jwt = handler.ReadJwtToken(result.AccessToken);
            var claims = new List<Claim>();

            var sub    = jwt.Claims.FirstOrDefault(c => c.Type == "sub")?.Value;
            var role   = jwt.Claims.FirstOrDefault(c => c.Type == "role")?.Value;
            var userId = jwt.Claims.FirstOrDefault(c => c.Type == "userId")?.Value;
            var uid    = jwt.Claims.FirstOrDefault(c => c.Type == "uid")?.Value;

            if (!string.IsNullOrEmpty(sub))
                claims.Add(new Claim(ClaimTypes.Name, sub));
            if (!string.IsNullOrEmpty(role))
                claims.Add(new Claim(ClaimTypes.Role, role));
            else
                claims.Add(new Claim(ClaimTypes.Role, "Staff"));
            if (!string.IsNullOrEmpty(userId))
                claims.Add(new Claim("userId", userId));
            if (!string.IsNullOrEmpty(uid))
                claims.Add(new Claim("uid", uid));

            // Store JWT tokens as claims so services can retrieve them
            // during the interactive circuit (where HttpContext is unavailable).
            claims.Add(new Claim("access_token", result.AccessToken));
            if (!string.IsNullOrEmpty(result.RefreshToken))
                claims.Add(new Claim("refresh_token", result.RefreshToken));

            var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
            var principal = new ClaimsPrincipal(identity);

            await HttpContext.SignInAsync(
                CookieAuthenticationDefaults.AuthenticationScheme,
                principal,
                new AuthenticationProperties
                {
                    IsPersistent = true,
                    ExpiresUtc = DateTimeOffset.UtcNow.AddHours(8)
                });

            Logger.LogInformation("[Login] Cookie issued for user: {Username}, role: {Role}", sub, role);

            // Full-page redirect so the browser picks up the new Set-Cookie header
            Navigation.NavigateTo("/main", forceLoad: true);
        }
        catch (NavigationException)
        {
            // NavigationException is thrown by NavigateTo during SSR to trigger
            // an HTTP redirect — this is expected, not a login failure.
            throw;
        }
        catch (Exception ex)
        {
            errorMessage = $"Login failed: {ex.Message}";
            Logger.LogError(ex, "[Login] Exception during login");
        }
    }

    private class LoginModel
    {
        public string? Username { get; set; }
        public string? Password { get; set; }
    }

    private class LoginResponse
    {
        public string? AccessToken { get; set; }
        public string? RefreshToken { get; set; }
        public int ExpiresIn { get; set; }
    }
}
