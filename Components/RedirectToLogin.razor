@inject NavigationManager Navigation

@*
    Redirect unauthenticated users to the login page.
    Used in <NotAuthorized> blocks of <AuthorizeView>.

    With cookie auth, the server knows auth state during SSR, so this
    redirect is reliable without the OnAfterRender timing workaround
    that was needed with sessionStorage-based auth.
*@

@code {
    protected override void OnInitialized()
    {
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
