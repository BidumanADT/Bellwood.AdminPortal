{
  "family": "bellwood-adminportal",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [ "FARGATE" ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::105319843299:role/bellwood-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::105319843299:role/bellwood-adminportal-task-role",
  "containerDefinitions": [
    {
      "name": "bellwood-adminportal",
      "image": "105319843299.dkr.ecr.us-east-1.amazonaws.com/bellwood-adminportal:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Alpha"
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": "http://+:8080"
        },
        {
          "name": "AdminAPI__BaseUrl",
          "value": "https://api.placeholder.local"
        },
        {
          "name": "AuthServer__BaseUrl",
          "value": "https://auth.placeholder.local"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bellwood-adminportal",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}